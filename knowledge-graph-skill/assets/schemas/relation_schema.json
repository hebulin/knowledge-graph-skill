{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Relation",
  "type": "object",
  "required": ["source_entity_id", "relation_type", "target_entity_id"],
  "properties": {
    "relation_id": {"type": "string", "pattern": "^rel_.*$"},
    "source_entity_id": {"type": "string"},
    "relation_type": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
    "target_entity_id": {"type": "string"},
    "attributes": {"type": "object", "additionalProperties": true},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1, "default": 1.0},
    "direction": {"type": "string", "enum": ["directed","undirected"], "default": "directed"},
    "valid_from": {"type": ["string","null"], "format": "date"},
    "valid_to": {"type": ["string","null"], "format": "date"},
    "provenance": {"type": "object"},
    "tenant_id": {"type": "string", "default": "default"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
